# NextAuth - Required for auth to work
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here
# Trust host for OAuth callbacks (Vercel, proxies). Set to true in production.
# AUTH_TRUST_HOST=true

# Database - use a connection pooler in production (Supabase port 6543, Neon -pooler)
# Add ?connection_limit=1 when using a pooler for serverless
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase (Storage for item cover uploads — server-only key, never commit real values)
# Bucket "item-covers" is created automatically on first upload when possible.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: custom domain for metadata/OG images (e.g. https://www.kanon.club)
# NEXT_PUBLIC_APP_URL=https://www.kanon.club
